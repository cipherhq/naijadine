{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "SUPABASE_SERVICE_ROLE_KEY",
        "PAYSTACK_SECRET_KEY",
        "PAYSTACK_STARTER_PLAN_CODE",
        "PAYSTACK_PROFESSIONAL_PLAN_CODE"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {},
    "type-check": {},
    "clean": {
      "cache": false
    }
  }
}
