# ═══════════════════════════════════════
# DineRoot Environment Variables
# Copy to .env.local and fill in values
# ═══════════════════════════════════════

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Vercel ──
VERCEL_URL=https://dineroot.com

# ── Payments ──
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_WEBHOOK_SECRET=whsk_...
FLUTTERWAVE_SECRET_KEY=FLWSECK-...
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-...

# ── WhatsApp (Gupshup) ──
GUPSHUP_API_KEY=your-gupshup-api-key
GUPSHUP_APP_NAME=DineRoot
GUPSHUP_PHONE_NUMBER=2348XXXXXXXXX
GUPSHUP_WEBHOOK_SECRET=your-webhook-secret

# ── Email (Resend) ──
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@dineroot.com
RESEND_REPLY_TO=support@dineroot.com

# ── SMS (Termii) ──
TERMII_API_KEY=TL...
TERMII_SENDER_ID=DineRoot
TERMII_SECRET_KEY=ts_...

# ── Push Notifications (Firebase) ──
FIREBASE_PROJECT_ID=dineroot-prod
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@dineroot-prod.iam.gserviceaccount.com

# ── Search (Meilisearch) ──
MEILISEARCH_HOST=https://ms-xxx.meilisearch.io
MEILISEARCH_API_KEY=master_key_...

# ── Redis (Upstash) ──
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ── Error Tracking (Sentry) ──
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ── App Config ──
NODE_ENV=development
APP_NAME=DineRoot
APP_URL=https://dineroot.com
DASHBOARD_URL=https://dashboard.dineroot.com
API_URL=https://api.dineroot.com
